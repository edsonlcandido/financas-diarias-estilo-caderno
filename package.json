{
  "name": "vue-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview --host 0.0.0.0 --port ${PORT:-3000}",
    "clean": "rm -rf dist dist-server",
    "lint": "vue-tsc --noEmit",
    "start": "node dist-server/server.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-vue": "^5.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-vue-next": "^0.546.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vue-tsc": "^2.2.0"
  }
}
